# Environment Configuration Example
# Copy this to .env and update values

# Backend Configuration
BACKEND_URL=http://localhost:8000
DEBUG=True

# Database
DATABASE_URL=sqlite:///./problems.db

# Important: In production, use PostgreSQL or MySQL
# DATABASE_URL=postgresql://user:password@localhost/localproblemsreporter

# AI Model Settings
AI_MODEL=yolov5s
AI_CONFIDENCE_THRESHOLD=0.45

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=["jpg", "jpeg", "png", "gif"]

# JWT Settings (when authentication is implemented)
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Password Reset / Email Configuration
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USE_SSL=false
RESET_PASSWORD_URL=http://localhost:3000/reset-password
